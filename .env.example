# Copy to .env and fill in. NEVER commit .env (it's gitignored).

# GoRest — get a free token at https://gorest.co.in/consumer/login
GOREST_BASE_URL=https://gorest.co.in/public/v2
GOREST_TOKEN=your_gorest_access_token_here

# DummyJSON — used for the dynamic login (JWT) demo. No token needed.
DUMMY_BASE_URL=https://dummyjson.com

# Master key for encrypting/decrypting secrets (src/utils/crypto.ts).
# Use any strong passphrase. Keep the real value ONLY in .env (never commit it).
CRYPTO_SECRET=change-me-to-a-long-random-passphrase

# Zenith HR admin login. Encrypt the password once:
#   npx tsx src/utils/crypto.ts encrypt "admin123"
# then paste the result here. Falls back to the public demo password if unset.
ADMIN_USERNAME=Admin
ADMIN_PASSWORD_ENC=paste_encrypted_value_here
